{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: clang++ build active file",
            "type": "shell",
            "command": "mkdir -p '${fileDirname}/output' && clang++ -std=c++11 '${file}' -o '${fileDirname}/output/${fileBasenameNoExtension}' && '${fileDirname}/output/${fileBasenameNoExtension}'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        }
    ]
}